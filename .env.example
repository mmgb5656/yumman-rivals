# ============================================
# YUMMAN RIVALS - Environment Variables
# ============================================
# Copia este archivo a .env.local y completa con tus credenciales
# ============================================

# Supabase Configuration
SUPABASE_URL=https://tu-proyecto.supabase.co
SUPABASE_ANON_KEY=tu-api-key-publica-aqui

# Analytics (opcional)
ENABLE_ANALYTICS=true

# Update Server (opcional - por defecto usa GitHub Releases)
# UPDATE_SERVER_URL=https://tu-servidor.com/updates

# Debug Mode (solo desarrollo)
DEBUG_MODE=false
